{
  "name": "dlsite-price-tracker",
  "version": "1.0.0",
  "description": "DLsite price history collector - low-load, diff-only",
  "main": "main.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node main.js",
    "discover": "node main.js --mode=discover",
    "fetch": "node main.js --mode=fetch",
    "status": "node main.js --mode=status"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "express": "^5.2.1",
    "node-cron": "^3.0.3",
    "sql.js": "^1.14.1"
  },
  "bin": "main.js",
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist",
    "assets": [
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "scripts": [
      "crawler/*.js",
      "config.js"
    ]
  }
}
